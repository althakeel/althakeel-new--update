# ImageKit credentials (server-side)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Primary dashboard admin email
NEXT_PUBLIC_PRIMARY_ADMIN_EMAIL=admin@example.com

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# WhatsApp chat widget (client-side)
# Use digits only with country code, e.g. 971555020940
NEXT_PUBLIC_WHATSAPP_CHAT_NUMBER=971555020940

# Firebase web app config
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdefghijklmnopqrstuvwxyz
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (server-side credential provisioning)
# Option A: Full service account JSON as one line
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com"}
# Option B: Individual values
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend email invitation setup
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Almahy <noreply@your-domain.com>
NEXT_PUBLIC_APP_URL=https://your-domain.com

# MongoDB content database
MONGODB_URI=mongodb+srv://althakeelcom_db_user:JSeRcPHwqdr55d5J@almahy.fqenrcr.mongodb.net/?appName=almahy
MONGODB_DB_NAME=almahy

# OpenAI (daily auto blog generation)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_PRODUCT_AUTOFILL_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional third-party image providers for contextual blog images
PEXELS_API_KEY=your_pexels_api_key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Optional third-party RSS sources (comma-separated)
THIRD_PARTY_BLOG_RSS_URLS=https://example.com/feed.xml,https://example.org/rss

# Optional third-party web source pages (comma-separated)
THIRD_PARTY_BLOG_WEB_URLS=https://www.khaleejtimes.com/uae/legal

# Protect auto generation endpoint (use one or both)
BLOGS_AUTOMATION_SECRET=replace_with_a_long_random_secret
CRON_SECRET=replace_with_the_same_or_another_random_secret
